generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  profileImage String?  @default("https://icon-library.com/images/anonymous-avatar-icon/anonymous-avatar-icon-25.jpg")
  role         Role
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  isVerified   Boolean  @default(false)

  prescribedMedications Prescription[] @relation("PrescribedMedications")
  issuedMedications     Prescription[] @relation("IssuedMedications")
  patients              Prescription[] @relation("patients")
  Expenses              Expenses[]
}

model UserVerification {
  id           String   @id @default(uuid())
  userId       String
  uniqueString String
  createdAt    DateTime
  expiresAt    DateTime
}

model PasswordReset {
  id          String   @id @default(uuid())
  userId      String
  resetString String
  createdAt   DateTime
  expiresAt   DateTime
}

model Appointment {
  id      String   @id @default(uuid())
  title   String
  start   DateTime
  end     DateTime
  type    String
  tooltip String
}

model Expenses {
  id             String   @id @default(uuid())
  title          String
  amount         Int
  date           DateTime
  authorizedBy   User?    @relation(fields: [authorizedById], references: [id])
  authorizedById String?
}

model Invoice {
  id           String @id @default(uuid())
  uniqueString String @unique
  billables    Json
  amount       Int
  quantity     Int
}

model Medication {
  id             String         @id @default(uuid())
  name           String         @unique
  manufacturer   String
  price          Int
  prescriptions  Prescription[] @relation("PrescriptionMedications")
  prescriptionId String?
}

model Prescription {
  id               String   @id @default(uuid())
  uniqueString     String   @unique
  prescriptionDate DateTime
  issueDate        DateTime
  prescribedById   String?
  issuedById       String?
  patientId        String?

  prescribedBy User?        @relation("PrescribedMedications", fields: [prescribedById], references: [id])
  issuedBy     User?        @relation("IssuedMedications", fields: [issuedById], references: [id])
  patient      User?        @relation("patients", fields: [patientId], references: [id])
  medications  Medication[] @relation("PrescriptionMedications")

  @@index([prescribedById])
  @@index([issuedById])
}

enum Role {
  DOCTOR
  PATIENT
  PHARMACIST
  NURSE
}
