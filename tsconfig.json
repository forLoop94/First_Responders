{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./build",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": [
    "server.ts",
    "controllers/**/*",
    "routes/**/*",
    "middlewares/**/*",
    "utils/**/*",
    "types/**/*",
    "prisma/**/*",
    "mailer.ts",
    "script.ts"
  ],
  "exclude": ["client", "node_modules", "dist", "client/**/*"]
}
